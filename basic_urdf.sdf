                        <ambient>1.0 0.45 0.0 1</ambient> <!-- R G B How the object looks in general lighting-->
                        <diffuse>1.0 0.45 0.0 1</diffuse> <!-- R G B main visible colour-->
                        <specular>0.2 0.2 0.2 1</specular> <!-- R G B How shiny the object looks, higher is shinier -->
