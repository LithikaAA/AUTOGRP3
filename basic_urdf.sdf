        <!-- ========================================================= 
                CRICKET BATTING CAGES ALONG THE SIDE OF THE OVAL             
            These are placed off to one side of the oval instead of at the
            tree end, so the two areas feel separate.
            The cages are lined up lengthwise with the field.     
             ========================================================= 

            Code for cricket batting cage frame:
            the large transparent box is the main net lane
            the smaller box visuals are the support posts and top bars
            one simple collision box is used so the whole cage behaves like
            a solid obstacle without needing collision on every single bar -->

        <model name="batting_cage_1">
            <static>true</static>
            <pose>11 0 0 0 0 0</pose>
            <link name="link">

                <visual name="lane_visual">
                    <pose>0 0 1.0 0 0 0</pose>
                    <geometry>
                        <box>
                            <size>1.5 6.0 2.0</size>
                        </box>
                    </geometry>
                    <material>
