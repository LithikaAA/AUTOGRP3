<?xml version="1.0" ?>
<sdf version="1.8">

<!-- Ground Plane of 100 x 100 m 
This gives enough space for the full oval, obstacles, and robot navigation without hitting boundaries.
The plane is flat with a normal of (0, 0, 1) so everything sits on it properly.
oval is centred roughly around the origin (0, 0).

location of obstacles:
All positions are written as:
(x, y, z)
Trees:
(-8, -20, 0)
(-6, -22, 0)
(-4, -24, 0)
(-2, -22, 0)
(0, -20, 0)
(2, -22, 0)
(4, -24, 0)
Batting cages:
(6, 20, 0)
Cricket pitch strip:
(0, 0, 0)
Cones/Buckets:
(-4, -10, 0)
(-2, -6, 0)
(2, -8, 0)
(4, -4, 0)
(-3, 2, 0)
(1, 4, 0)
(3, 6, 0)
(-4, 8, 0)
(-1, 10, 0)
(2, 12, 0)
(4, 14, 0)
-->


    <!--Physics set up for the simulation-->
    <world name="pioneer_world">
        <physics name="1ms" type="ignored">
            <max_step_size>0.001</max_step_size>
            <real_time_factor>1.0</real_time_factor>
        </physics>
    
    <!--Core Gazebo simulation systems-->
        <plugin
            filename="libgz-sim-physics-system"
            name="gz::sim::systems::Physics">
        </plugin>
        <plugin
            filename="libgz-sim-user-commands-system"
            name="gz::sim::systems::UserCommands">
        </plugin>
        <plugin
            filename="libgz-sim-scene-broadcaster-system"
            name="gz::sim::systems::SceneBroadcaster">
        </plugin>
        <plugin filename="libgz-sim-imu-system"
                name="gz::sim::systems::Imu">
        </plugin>
        <plugin filename="libgz-sim-sensors-system.so"
                name="gz::sim::systems::Sensors">
        </plugin>
        <plugin filename="libgz-sim-contact-system"
                name="gz::sim::systems::Contact">
        </plugin>

        <!--Sun/ Lighting for the whole world-->
        <light type="directional" name="sun">
                <cast_shadows>true</cast_shadows>
                <pose>0 0 10 0 0 0</pose>
                <diffuse>0.8 0.8 0.8 1</diffuse>
                <specular>0.2 0.2 0.2 1</specular>
                <attenuation>
                    <range>1000</range>
                    <constant>0.9</constant>
                    <linear>0.01</linear>
                    <quadratic>0.001</quadratic>
                </attenuation>
                <direction>-0.5 0.1 -0.9</direction>
            </light>
            

            <!-- code for the base ground plane
            This gives gazebo a large flat surface to simulate the ground-->
            <model name="ground_plane">
                <static>true</static>
                <link name="link">
                    <collision name="collision">
                    <geometry>
                        <plane>
                        <normal>0 0 1</normal>
                        </plane>
                    </geometry>
                    </collision>
                    <visual name="visual">
                    <geometry>
                        <plane>
                        <normal>0 0 1</normal>
                        <size>100 100</size>
                        </plane>
                    </geometry>
                    <material>
                        <ambient>0.8 0.8 0.8 1</ambient>
                        <diffuse>0.8 0.8 0.8 1</diffuse>
                        <specular>0.8 0.8 0.8 1</specular>
                    </material>
                    </visual>
                </link>
            </model>

        <!-- Code for the grass field
        This is the green area that makes it feel more like James Oval -->
        <model name="grass_field">
            <static>true</static>
            <pose>0 0 0.01 0 0 0</pose>
            <link name="field_link">
                <visual name="field_visual">
                    <geometry>
                        <box>
                            <size>34 24 0.02</size>
                        </box>
                    </geometry>
                    <material>
                        <ambient>0.18 0.55 0.18 1</ambient>
                        <diffuse>0.18 0.55 0.18 1</diffuse>
                        <specular>0.05 0.05 0.05 1</specular>
                    </material>
                </visual>
            </link>
        </model>

        <!-- ========================================================= 
                                OVAL OUTLINE                                              
            These are only visual white line markers.                 
            They show the oval shape but do not block the robot.      
            ========================================================== 

            Code for oval outline marker at top centre [0, 7] 
            static means it stays fixed 
            pose sets where the line piece sits 
            z is very small so it looks like paint on the ground 
            box geometry makes a thin white line segment -->

        <!-- Top half of the oval -->
                <model name="oval_line_1">
                    <static>true</static>
                    <pose>0 9.5 0.02 0 0 0</pose>
                    <link name="link">
                        <visual name="visual">
                            <geometry><box><size>2.2 0.12 0.02</size></box></geometry>
                            <material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse><specular>0.2 0.2 0.2 1</specular></material>
                        </visual>
                    </link>
                </model>

                <model name="oval_line_2">
                    <static>true</static>
                    <pose>3.0 8.7 0.02 0 0 -0.28</pose>
                    <link name="link">
