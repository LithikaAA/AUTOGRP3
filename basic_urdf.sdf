        <!-- Code for centre cricket pitch strip 
        This is the brown rectangle placed in the middle of the oval
        pose puts it in the centre of the map
        the small z value lifts it slightly above the grass so it is visible
        box size makes it long and narrow like a cricket pitch -->
        <model name="cricket_pitch_strip">
            <static>true</static>
            <pose>0 0 0.02 0 0 0</pose>
            <link name="pitch_link">
                <visual name="pitch_visual">
                    <geometry>
                        <box>
                            <size>1.4 10.0 0.03</size>
                        </box>
                    </geometry>
                    <material>
                        <ambient>0.65 0.52 0.32 1</ambient>
                        <diffuse>0.65 0.52 0.32 1</diffuse>
                        <specular>0.1 0.1 0.1 1</specular>
                    </material>
                </visual>
            </link>
        </model>

        <!-- ========================================================= 
                            OBSTACLES INSIDE THE OVAL                                
             ========================================================= 
            
            Format for obstacles < x y z roll pitch yaw >
            Code for cone at location [2, 1]
            pose places the cone in the field 
            cylinder is being used as a simple stand-in obstacle -->
        <model name="cone_1">
            <static>true</static>
            <pose>2 1 0.3 0 0 0</pose>
            <link name="link">
                <visual name="visual">
                    <geometry>
                        <cylinder>
                            <radius>0.2</radius>
                            <length>0.6</length>
                        </cylinder>
                    </geometry>
                    <material>
                        <ambient>1.0 0.45 0.0 1</ambient>
                        <diffuse>1.0 0.45 0.0 1</diffuse>
                        <specular>0.2 0.2 0.2 1</specular>
                    </material>
                </visual>
                <collision name="collision">
                    <geometry>
                        <cylinder>
                            <radius>0.2</radius>
                            <length>0.6</length>
                        </cylinder>
                    </geometry>
                </collision>
            </link>
        </model>

